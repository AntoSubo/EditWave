<Window x:Class="EditWave.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EditWave"
        mc:Ignorable="d"
        Title="EditWave" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/><!--основная часть-->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Файл">
                <MenuItem Header="Открыть" Command="{Binding OpenProjectCommand}"/>
                <MenuItem Header="Сохранить" Command="{Binding SaveProjectCommand}"/>
                <Separator/>
                <MenuItem Header="Выход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="Правка">
                <MenuItem Header="Обрезать" Command="{Binding TrimCommand}"/>
                <MenuItem Header="Удалить" Command="{Binding DeleteCommand}"/>
            </MenuItem>
            <MenuItem Header="Эффекты">
                <MenuItem Header="Усиление" Command="{Binding ApplyGainCommand}"/>
                <MenuItem Header="Реверс" Command="{Binding ApplyReverseCommand}"/>
            </MenuItem>
            <MenuItem Header="Справка">
                <MenuItem Header="О программе" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>

        <ToolBar Grid.Row="1">
            <Button Command="{Binding PlayCommand}" Content="▶" Margin="5" Padding="5"/>
            <Button Command="{Binding PauseCommand}" Content="⏸" Margin="5" Padding="5"/>
            <Button Command="{Binding StopCommand}" Content="⏹" Margin="5" Padding="5"/>
            <Separator/>
            <Button Command="{Binding TrimCommand}" Content="Обрезать" Margin="5" Padding="5"/>
            <Button Command="{Binding DeleteCommand}" Content="Удалить" Margin="5" Padding="5"/>
            <Button Command="{Binding ApplyGainCommand}" Content="Усиление" Margin="5" Padding="5"/>
            <Button Command="{Binding ApplyReverseCommand}" Content="Реверс" Margin="5" Padding="5"/>
            <Separator/>
            <Button Command="{Binding SaveProjectCommand}" Content="💾" Margin="5" Padding="5"/>
        </ToolBar>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>                         

            <Border Grid.Column="0" Margin="5" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#666" Margin="10">
                        <TextBlock Text="заглушка" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   Foreground="Beige"/>
                    </Border>
                    <!--TODO чтоб привязка нормальная была а не заглушка-->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
                        <TextBlock Text="0:00" Margin="10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="1:00" Margin="10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="2:00" Margin="10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="3:00" Margin="10,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="5" CornerRadius="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="Эффекты" Margin="10"/>
                        <TextBlock Text="Усиление:" Margin="10"/>
                        <Slider Minimum="0" Maximum="200" Value="{Binding Gain}" Margin="10"/>
                        <TextBlock Text="{Binding Gain, StringFormat={}{0:F0}%}" HorizontalAlignment="Right" Margin="10,0,10,5"/>
                        <Button Command="{Binding ApplyGainCommand}" Content="Применить усиление" Margin="10"/>
                        <Button Command="{Binding ApplyReverseCommand}" Content="Применить реверс" Margin="10"/>
                        <Separator Margin="10"/>
                        <TextBlock Text="Проекты" Margin="10"/>

                        <ListBox ItemsSource="{Binding ProjectsList}" 
                        SelectedItem="{Binding SelectedProject}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding CreatedAt}" FontSize="10" Foreground="Gray"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="Открыть" Margin="0,0,5,0" Padding="10,5"/>
                            <Button Content="Удалить" Padding="10,5"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#1E1E1E" Padding="10" Margin="5,0,5,5" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>


                <TextBlock Grid.Column="0" Text="{Binding CurrentTime}" VerticalAlignment="Center" Margin="0,0,10,0"/>


                <Slider Grid.Column="1" Value="{Binding CurrentPosition}" Maximum="{Binding Duration}" Margin="10,0"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Громкость:" Margin="0,0,5,0"/>
                    <Slider Width="100" Minimum="0" Maximum="1" Value="{Binding Volume}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>