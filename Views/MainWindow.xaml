<Window x:Class="EditWave.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EditWave.Views"
        Title="EditWave" Height="500" Width="900"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="#E0E0E0" Foreground="#333">
            <MenuItem Header="Файл">
                <MenuItem Header="Открыть" Command="{Binding OpenProjectCommand}"/>
                <MenuItem Header="Сохранить" Command="{Binding SaveProjectCommand}"/>
                <Separator/>
                <MenuItem Header="Выход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="Правка">
                <MenuItem Header="Обрезать" Command="{Binding TrimCommand}"/>
                <MenuItem Header="Удалить" Command="{Binding DeleteCommand}"/>
            </MenuItem>
            <MenuItem Header="Эффекты">
                <MenuItem Header="Усиление" Command="{Binding ApplyGainCommand}"/>
                <MenuItem Header="Реверс" Command="{Binding ApplyReverseCommand}"/>
            </MenuItem>
            <MenuItem Header="Справка">
                <MenuItem Header="О программе" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>

        <ToolBar Grid.Row="1" Background="#E0E0E0">
            <Button Command="{Binding PlayCommand}" Content="▶" Margin="2" Padding="5" Background="White" Foreground="#FF4081"/>
            <Button Command="{Binding PauseCommand}" Content="⏸" Margin="2" Padding="5" Background="White" Foreground="#FF4081"/>
            <Button Command="{Binding StopCommand}" Content="⏹" Margin="2" Padding="5" Background="White" Foreground="#FF4081"/>
            <Separator/>
            <Button Command="{Binding DeleteCommand}" Content="✂ Удалить" Margin="2" Padding="5" Background="White" Foreground="#FF4081"/>
            <Button Command="{Binding TrimCommand}" Content="✂ Обрезать" Margin="2" Padding="5" Background="White" Foreground="#FF4081"/>
            <Button Command="{Binding SaveProjectCommand}" Content="💾 Сохранить" Margin="2" Padding="5" Background="White" Foreground="#FF4081"/>
        </ToolBar>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="10" Background="White" CornerRadius="5" BorderBrush="#CCC" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>
                    <views:WaveformControl x:Name="WaveformControl"
                                           Samples="{Binding WaveformSamples}"
                                           Duration="{Binding Duration}"
                                           SelectionChanged="OnWaveformSelectionChanged"
                                           Margin="5"/>

                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="10" Background="#E0E0E0" CornerRadius="5" BorderBrush="#CCC" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="Эффекты" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>
                        <TextBlock Text="Усиление:" Foreground="#333"/>
                        <Slider Minimum="0" Maximum="200" Value="{Binding Gain}" Margin="0,5"/>
                        <TextBlock Text="{Binding Gain, StringFormat={}{0:F0}%}" HorizontalAlignment="Right" Foreground="#333"/>
                        <Button Command="{Binding ApplyGainCommand}" Content="Применить усиление" Margin="5"/>
                        <Button Command="{Binding ApplyReverseCommand}" Content="Применить реверс" Margin="5"/>
                        <Separator Margin="10"/>
                        <TextBlock Text="Проекты" FontWeight="Bold" Foreground="#333" Margin="0,10,0,5"/>
                        <ListBox Height="150" ItemsSource="{Binding ProjectsList}" SelectedItem="{Binding SelectedProject}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" Foreground="#333"/>
                                        <Button Grid.Column="1" Content="X" Background="Transparent" Foreground="Red" BorderThickness="0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#E0E0E0" Padding="10" Margin="5,0,5,5" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding CurrentTime}" VerticalAlignment="Center" Foreground="#333" Margin="0,0,10,0"/>
                <Slider Grid.Column="1" Value="{Binding CurrentPosition}" Maximum="{Binding Duration}" Margin="10,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Громкость:" Margin="0,0,5,0" Foreground="#333"/>
                    <Slider Width="100" Minimum="0" Maximum="1" Value="{Binding Volume}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>