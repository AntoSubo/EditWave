<UserControl x:Class="EditWave.Views.WaveformControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0A0A0A">
    <Canvas x:Name="WaveCanvas" Background="#0A0A0A">
        <Polyline x:Name="WaveTop"
                  Stroke="#FF4081"
                  StrokeThickness="1"
                  StrokeLineJoin="Round"/>
        <Polyline x:Name="WaveBottom"
                  Stroke="#FF4081"
                  StrokeThickness="1"
                  StrokeLineJoin="Round"/>
    </Canvas>
</UserControl>