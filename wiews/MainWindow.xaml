<Window x:Class="EditWave.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EditWave"
        mc:Ignorable="d"
        Title="EditWave" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/><!--основная часть-->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Файл">
                <MenuItem Header="Открыть"/>
                <MenuItem Header="Сохранить"/>
                <MenuItem Header="Экспорт"/>
                <Separator/>
                <MenuItem Header="Выход"/>
            </MenuItem>
            <MenuItem Header="Правка">
                <MenuItem Header="Обрезать"/>
                <MenuItem Header="Удалить"/>
            </MenuItem>
            <MenuItem Header="Эффекты">
                <MenuItem Header="Усиление"/>
                <MenuItem Header="Реверс"/>
            </MenuItem>
            <MenuItem Header="Справка">
                <MenuItem Header="О программе"/>
            </MenuItem>
        </Menu>

        <ToolBar Grid.Row="1">
            <Button Content="▶" Margin="5" Padding="5"/>
            <Button Content="⏸" Margin="5" Padding="5"/>
            <Button Content="⏹" Margin="5" Padding="5"/>
            <Separator/>
            <Button Content="Обрезать" Margin="5" Padding="5"/>
            <Button Content="Удалить" Margin="5" Padding="5"/>
            <Button Content="Усиление" Margin="5" Padding="5"/>
            <Button Content="Реверс" Margin="5" Padding="5"/>
            <Separator/>
            <Button Content="💾" Margin="5" Padding="5"/>
        </ToolBar>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>                         

            <Border Grid.Column="0" Margin="5" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#666" Margin="10">
                        <TextBlock Text="заглушка" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   Foreground="Beige"/>
                    </Border>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
                        <TextBlock Text="0:00" Margin="10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="1:00" Margin="10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="2:00" Margin="10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="3:00" Margin="10,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="5" CornerRadius="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="Эффекты" Margin="10"/>
                        <TextBlock Text="Усиление:" Margin="10"/>
                        <Slider Margin="10"/>
                        <Button Content="Применить реверс" Margin="10"/>
                        <Separator Margin="10"/>
                        <TextBlock Text="Проекты" Margin="10"/>

                        <ListBox Height="150">
                            <ListBoxItem>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="пуппу" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="X" Background="Transparent"
                                            Foreground="Red" BorderThickness="0"/>
                                </Grid>
                            </ListBoxItem>
                        </ListBox>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="Открыть" Margin="0,0,5,0" Padding="10,5"/>
                            <Button Content="Удалить" Padding="10,5"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#1E1E1E" Padding="10" Margin="5,0,5,5" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Slider Grid.Column="1" Margin="10,0"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Громкость:" Margin="0,0,5,0"/>
                    <Slider Width="100" Minimum="0" Maximum="1" Value="0.5"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>